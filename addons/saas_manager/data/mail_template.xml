<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_saas_renewal" model="mail.template">
            <field name="name">SaaS: License Renewal</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Renewal of your license {{ object.client_order_ref or 'SaaS' }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="description">Sent automatically for license renewal</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello <t t-out="object.partner_id.name or ''">Client</t>,
                        <br/><br/>
                        Your software license is expiring soon.
                        To ensure service continuity without interruption, we have prepared the renewal quotation attached.
                        <br/><br/>
                        <strong>Details:</strong>
                        <br/>
                        Amount: <strong t-out="format_amount(object.amount_total, object.currency_id) or ''"></strong>
                        <br/>
                        Validity: Next period
                        <br/><br/>
                        You can review, sign, and pay this quotation online by clicking the button below:
                        <br/><br/>
                        <div style="text-align: center; margin: 16px 0px;">
                            <a t-att-href="object.get_portal_url()"
                               style="background-color: #875A7B; padding: 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size: 16px;">
                                <i class="fa fa-check-circle"></i> Renew my License
                            </a>
                        </div>
                        <br/><br/>
                        If you have any questions, do not hesitate to reply to this email.
                        <br/><br/>
                        Best regards,
                        <br/>
                        <t t-out="object.company_id.name or ''"></t>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>