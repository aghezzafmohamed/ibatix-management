<odoo>

    <record id="view_saas_environment_form_split" model="ir.ui.view">
        <field name="name">saas.environment.form.split</field>
        <field name="model">saas.environment</field>
        <field name="arch" type="xml">
            <form string="Service Instance">
                <header>
<button name="action_provision_full_stack"
                        string="🚀 Deploy Full Stack"
                        type="object"
                        class="btn-primary"
                        invisible="coolify_uuid != False"
                        confirm="This will create the Project, Environment, and Service on Coolify. Are you sure?"/>

                <button name="action_magic_login"
                        string="Admin Login (SSO)"
                        type="object"
                        class="btn-secondary"
                        icon="fa-magic"
                        invisible="state != 'running'"/>

                <button string="Start All" type="object" name="action_start"
                        invisible="coolify_uuid == False"/> <button string="Stop All" type="object" name="action_stop" class="btn-danger"
                        invisible="coolify_uuid == False"/>

                <button string="Restart All" type="object" name="action_restart" class="btn-warning"
                        invisible="coolify_uuid == False"/>

                <button string="Refresh Logs &amp; Status" type="object" name="action_refresh_all" icon="fa-refresh" class="btn-secondary"
                        invisible="coolify_uuid == False"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <field name="domain_url" widget="url" placeholder="https://..."/>
                    </div>
                    <group>
                        <group>
                            <field name="instance_id"/>
                            <field name="env_type"/>
                        </group>
                        <group>
                            <field name="coolify_uuid" string="Service UUID (Stack)"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Odoo Service">
                            <group>
                                <group>
                                    <field name="odoo_status" widget="badge"
                                           decoration-success="odoo_status == 'running'"
                                           decoration-danger="odoo_status in ('stopped', 'exited')"/>
                                </group>
                                <group>
                                    <field name="odoo_uuid"/>
                                    <field name="odoo_image"/>
                                </group>
                            </group>
                            <separator string="Odoo Console"/>
                            <field name="odoo_logs" widget="html" nolabel="1"/>
                        </page>
                        <page string="PostgreSQL Service">
                             <group>
                                <group>
                                    <field name="postgres_status" widget="badge"
                                           decoration-success="postgres_status == 'running'"
                                           decoration-danger="postgres_status in ('stopped', 'exited')"/>
                                </group>
                                <group>
                                    <field name="postgres_uuid"/>
                                    <field name="postgres_image"/>
                                </group>
                            </group>
                            <separator string="PostgreSQL Console"/>
                            <field name="postgres_logs" widget="html" nolabel="1"/>
                        </page>
                        <page string="Environment Variables (Secrets)">
                            <div class="alert alert-info" role="alert">
                                <i class="fa fa-info-circle"/> Modifications here will only take effect after a <b>Restart</b> of the service.
                            </div>

                            <div class="mb-2">
                                <button name="action_fetch_vars" string="Import from Coolify" type="object" icon="fa-download" class="btn-secondary me-2"/>
                                <button name="action_push_vars" string="Push to Coolify" type="object" icon="fa-upload" class="btn-primary" confirm="Warning: This will overwrite variables on Coolify. Continue?"/>
                            </div>

                            <field name="variable_ids">
                                <list editable="bottom">
                                    <field name="key" decoration-bf="1"/>
                                    <field name="value"/> <field name="is_preview" optional="hide"/>
                                    <field name="is_build_time" optional="hide"/>
                                    <field name="is_literal" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Docker Configuration (Compose)">
                            <div class="d-flex justify-content-between align-items-center mb-2 mt-1">
                                <div class="alert alert-warning mb-0 py-1" role="alert">
                                    <i class="fa fa-exclamation-triangle"/>
                                    <strong>Warning:</strong> Modifying this file may break the service.
                                </div>

                                <button name="action_save_compose"
                                        string="Save to Coolify"
                                        type="object"
                                        icon="fa-cloud-upload"
                                        class="btn-primary"
                                        confirm="Are you sure you want to modify the Docker configuration? This will overwrite the current configuration on Coolify."/>
                            </div>
                            <field name="docker_compose" widget="text"
                                   placeholder="services:&#10;  odoo:..."
                                   style="font-family: 'Courier New', monospace; background: #282c34; color: #abb2bf; padding: 15px; border-radius: 5px; width: 100%; min-height: 600px; white-space: pre;"/>
                        </page>
                        <page string="Deployment Configuration">
                            <group>
                                <group string="GitHub Source">
                                    <field name="github_url" widget="url"/>
                                    <field name="github_branch"/>
                                    <field name="github_token" password="True" placeholder="ghp_..."/>
                                </group>
                                <group string="Odoo Security">
                                    <field name="odoo_master_password" password="True"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_saas_environment_kanban" model="ir.ui.view">
        <field name="name">saas.environment.kanban</field>
        <field name="model">saas.environment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" highlight_color="state">
                <field name="id"/>
                <field name="name"/>
                <field name="state"/>
                <field name="domain_url"/>
                <field name="env_type"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong class="o_kanban_record_title fs-5">
                                <field name="name"/>
                            </strong>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {'running': 'success', 'stopped': 'danger', 'restarting': 'warning'}}"/>
                        </div>

                        <div class="d-flex flex-column gap-1 flex-grow-1">
                            <div t-if="record.domain_url.raw_value" class="text-truncate">
                                <i class="fa fa-external-link me-2 text-primary" title="URL"/>
                                <a t-att-href="record.domain_url.raw_value" target="_blank" class="text-decoration-none">
                                    <field name="domain_url"/>
                                </a>
                            </div>
                            <div class="text-muted small">
                                <i class="fa fa-server me-2"/>
                                <field name="env_type"/>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-3 border-top pt-2">
                            <div class="btn-group btn-group-sm" role="group">
                                <button name="action_start" type="object"
                                        class="btn btn-outline-success"
                                        title="Start"
                                        invisible="state == 'running'">
                                    <i class="fa fa-play"/>
                                </button>
                                <button name="action_stop" type="object"
                                        class="btn btn-outline-danger"
                                        title="Stop"
                                        invisible="state != 'running'">
                                    <i class="fa fa-stop"/>
                                </button>
                                <button name="action_restart" type="object"
                                        class="btn btn-outline-warning"
                                        title="Restart">
                                    <i class="fa fa-refresh"/>
                                </button>
                                <button name="action_fetch_logs" type="object"
                                        class="btn btn-outline-secondary"
                                        title="Logs">
                                    <i class="fa fa-file-text-o"/>
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_saas_environment_all" model="ir.actions.act_window">
        <field name="name">All Environments</field>
        <field name="res_model">saas.environment</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create your first Coolify instance!
          </p>
        </field>
    </record>

</odoo>