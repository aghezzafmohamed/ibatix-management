<odoo>
    <record id="view_saas_license_form" model="ir.ui.view">
        <field name="name">saas.license.form</field>
        <field name="model">saas.license</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_quotation"
                            string="Create Quotation"
                            type="object"
                            class="btn-primary"
                            invisible="sale_order_id != False"/>

                    <button name="action_send_quotation_email"
                            string="Send by Email"
                            type="object"
                            class="btn-secondary"
                            invisible="sale_order_id == False"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-usd"
                                invisible="sale_order_id == False">
                            Quotation
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="type_id"/>
                        <h1><field name="type_id"/></h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="instance_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group string="Billing">
                            <field name="token"/>
                            <field name="renewal_license_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ir_cron_saas_license_renewal" model="ir.cron">
        <field name="name">SaaS Manager: Auto License Renewal</field>
        <field name="model_id" ref="model_saas_license"/>
        <field name="state">code</field>
        <field name="code">model._cron_manage_renewals()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>