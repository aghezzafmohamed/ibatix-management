<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_ibatix_fonts" inherit_id="website.layout" name="Ibatix Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
            <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=Epilogue:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
        </xpath>
    </template>

    <template id="theme_ibatix_homepage" inherit_id="website.homepage" name="Ibatix Homepage">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="ibatix-app">
                <nav>
                  <a class="nav-logo" href="#">
                    <img src="/theme_ibatix/static/src/img/logo.png" width="100px"/>
                  </a>
                  <ul class="nav-links">
                    <li><a href="#features">Fonctionnalités</a></li>
                    <li><a href="#modules">Modules</a></li>
                    <li><a href="#ia">Intelligence IA</a></li>
                    <li><a href="#conformite">Conformité</a></li>
                    <li><a href="#" class="nav-cta open-demo">Demander une démo</a></li>
                  </ul>
                  <button class="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false">
                    <span></span><span></span><span></span>
                  </button>
                </nav>

                <div class="mobile-menu" role="dialog" aria-label="Navigation mobile">
                  <a href="#features" class="mobile-link">Fonctionnalités</a>
                  <a href="#modules" class="mobile-link">Modules</a>
                  <a href="#ia" class="mobile-link">Intelligence IA</a>
                  <a href="#conformite" class="mobile-link">Conformité</a>
                  <a href="#" class="nav-cta open-demo">Demander une démo</a>
                </div>

                <section id="hero">
                  <div class="hero-bg"></div>
                  <div class="hero-grid-lines"></div>
                  <div class="hero-content">
                    <div class="hero-tag">Logiciel 100 % cloud · Rénovation énergétique</div>
                    <h1>Gérez votre activité,<br /><em>révolutionnez</em><br />votre croissance.</h1>
                    <p class="hero-desc">
                      Ibatix est la suite de gestion tout-en-un pensée pour les entreprises de la rénovation énergétique. Devis, chantiers, primes CEE/MPR, conformité — tout en un seul outil.
                    </p>
                    <div class="hero-actions">
                      <a href="#" class="btn-primary open-demo">
                          Demander une démonstration
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                      <a href="#features" class="btn-secondary">Découvrir les modules</a>
                    </div>
                  </div>
                  <div class="hero-visual">
                    <div class="dashboard-card">
                      <div class="dash-header">
                        <span class="dash-title">Tableau de bord</span>
                        <span class="dash-badge">En direct</span>
                      </div>
                      <div class="dash-metric-row">
                        <div class="dash-metric">
                          <div class="dash-metric-val">18<span>k€</span></div>
                          <div class="dash-metric-label">Devis ce mois</div>
                        </div>
                        <div class="dash-metric">
                          <div class="dash-metric-val">94<span>%</span></div>
                          <div class="dash-metric-label">Taux de conformité</div>
                        </div>
                      </div>
                      <div class="dash-bar-section">
                        <div class="dash-bar-label"><strong>Prime CEE calculée</strong><span>4 250 €</span></div>
                        <div class="dash-bar-track"><div class="dash-bar-fill" style="width:72%"></div></div>
                        <div class="dash-bar-label"><strong>MaPrimeRénov'</strong><span>2 800 €</span></div>
                        <div class="dash-bar-track"><div class="dash-bar-fill" style="width:55%; animation-delay:0.3s"></div></div>
                        <div class="dash-bar-label"><strong>Primes régionales</strong><span>1 100 €</span></div>
                        <div class="dash-bar-track"><div class="dash-bar-fill" style="width:32%; animation-delay:0.6s"></div></div>
                      </div>
                      <div class="dash-pills">
                        <span class="dash-pill active">Devis signé</span>
                        <span class="dash-pill active">Cerfa généré</span>
                        <span class="dash-pill">Facture</span>
                        <span class="dash-pill">Réception</span>
                      </div>
                    </div>
                  </div>
                </section>

                <div id="stats">
                  <div class="stat-item reveal">
                    <div class="stat-num"><span class="counter" data-target="400">0</span><span>+</span></div>
                    <div class="stat-label">Entreprises clientes</div>
                  </div>
                  <div class="stat-item reveal">
                    <div class="stat-num"><span class="counter" data-target="1400">0</span><span>+</span></div>
                    <div class="stat-label">Artisans accompagnés</div>
                  </div>
                  <div class="stat-item reveal">
                    <div class="stat-num"><span class="counter" data-target="5000">0</span><span>+</span></div>
                    <div class="stat-label">Utilisateurs actifs</div>
                  </div>
                  <div class="stat-item reveal">
                    <div class="stat-num"><span class="counter" data-target="45">0</span></div>
                    <div class="stat-label">Modules disponibles</div>
                  </div>
                </div>

                <section id="features">
                  <div class="features-header reveal">
                    <div>
                      <span class="section-tag">Fonctionnalités</span>
                      <h2>Tout ce dont votre<br />entreprise a <em>besoin</em></h2>
                    </div>
                    <p class="section-lead">
                      De la prospection client à la réception de chantier, Ibatix couvre l'intégralité de vos processus métier avec 45 modules interconnectés.
                    </p>
                  </div>
                  <div class="features-grid">
                    <div class="feature-card reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg></div>
                      <div class="feature-title">Devis &amp; signature électronique</div>
                      <p class="feature-desc">Créez des devis professionnels et faites-les signer directement sur tablette, où que vous soyez sur le terrain.</p>
                    </div>
                    <div class="feature-card featured reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M14.5 9a2.5 2.5 0 0 0-5 0c0 1.4.9 2.2 2.5 2.5s2.5 1.1 2.5 2.5a2.5 2.5 0 0 1-5 0M12 6v1m0 10v1"/></svg></div>
                      <div class="feature-title">Calcul automatique des primes</div>
                      <p class="feature-desc">CEE, MaPrimeRénov', primes régionales — Ibatix calcule et intègre automatiquement toutes les aides disponibles pour chaque dossier.</p>
                    </div>
                    <div class="feature-card reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg></div>
                      <div class="feature-title">Planification de chantiers</div>
                      <p class="feature-desc">Gérez vos équipes, sous-traitants et interventions depuis un planning visuel clair et partagé en temps réel.</p>
                    </div>
                    <div class="feature-card reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2.5"/></svg></div>
                      <div class="feature-title">Visites techniques géolocalisées</div>
                      <p class="feature-desc">Horodatage et géolocalisation automatiques de chaque visite. Dossiers dématérialisés, zéro papier.</p>
                    </div>
                    <div class="feature-card reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg></div>
                      <div class="feature-title">Comptabilité &amp; achats</div>
                      <p class="feature-desc">Plan comptable français intégré, gestion des stocks et des fournisseurs pour une vision financière complète.</p>
                    </div>
                    <div class="feature-card reveal">
                      <div class="feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="3"/><path d="M3 20v-2a5 5 0 0 1 5-5h2"/><circle cx="17" cy="11" r="3"/><path d="M21 20v-1a4 4 0 0 0-4-4h-2a4 4 0 0 0-4 4v1"/></svg></div>
                      <div class="feature-title">CRM &amp; gestion commerciale</div>
                      <p class="feature-desc">Suivez vos prospects, clients et opportunités depuis un CRM pensé pour le secteur de la rénovation.</p>
                    </div>
                  </div>
                </section>

                <section id="modules">
                  <div class="modules-layout">
                    <div>
                      <span class="section-tag">45 modules</span>
                      <h2>Une suite <em>complète</em><br />et modulaire</h2>
                      <p class="section-lead" style="margin-bottom:40px">Activez uniquement ce dont vous avez besoin. Chaque module s'intègre parfaitement aux autres pour une gestion fluide de bout en bout.</p>
                      <div class="module-list" id="moduleList">
                        <div class="module-item active" data-module="crm">
                          <div class="module-dot"></div>
                          <span>CRM &amp; Prospection</span>
                          <span class="module-count">8 modules</span>
                        </div>
                        <div class="module-item" data-module="devis">
                          <div class="module-dot"></div>
                          <span>Devis &amp; Facturation</span>
                          <span class="module-count">6 modules</span>
                        </div>
                        <div class="module-item" data-module="chantier">
                          <div class="module-dot"></div>
                          <span>Gestion de chantier</span>
                          <span class="module-count">9 modules</span>
                        </div>
                        <div class="module-item" data-module="primes">
                          <div class="module-dot"></div>
                          <span>Primes énergétiques</span>
                          <span class="module-count">7 modules</span>
                        </div>
                        <div class="module-item" data-module="compta">
                          <div class="module-dot"></div>
                          <span>Comptabilité &amp; Achats</span>
                          <span class="module-count">10 modules</span>
                        </div>
                        <div class="module-item" data-module="conformite">
                          <div class="module-dot"></div>
                          <span>Conformité &amp; Documents</span>
                          <span class="module-count">5 modules</span>
                        </div>
                      </div>
                    </div>
                    <div class="modules-display" id="moduleDisplay">
                      <h3>CRM &amp; Prospection</h3>
                      <p>Gérez l'intégralité de votre cycle de vente, de la première prise de contact à la signature du devis. Suivez vos leads, automatisez vos relances et analysez vos performances commerciales.</p>
                      <div class="module-chips">
                        <span class="chip">Pipeline de vente</span>
                        <span class="chip">Suivi des leads</span>
                        <span class="chip">Relances automatiques</span>
                        <span class="chip">Historique client</span>
                        <span class="chip">Rapports commerciaux</span>
                        <span class="chip">Import/export contacts</span>
                      </div>
                    </div>
                  </div>
                </section>

                <section id="ia">
                  <div class="ia-layout">
                    <div class="ia-cards reveal">
                      <div class="ia-card">
                        <div class="ia-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v1h1a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1V6a4 4 0 0 1 4-4z"/><circle cx="12" cy="13" r="2"/><path d="M12 15v2"/></svg></div>
                        <h4>Vérification de conformité</h4>
                        <p>L'IA analyse chaque dossier et signale automatiquement les anomalies avant soumission.</p>
                      </div>
                      <div class="ia-card">
                        <div class="ia-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg></div>
                        <h4>Chatbot client</h4>
                        <p>Un assistant IA répond à vos clients 24h/24 sur l'avancement de leurs travaux.</p>
                      </div>
                      <div class="ia-card wide">
                        <div class="ia-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><path d="M9 14l2 2 4-4"/></svg></div>
                        <h4>Gestion documentaire intelligente</h4>
                        <p>Classement, extraction et contrôle automatiques de vos documents Cerfa, attestations et PV de réception. Gagnez des heures chaque semaine sur les tâches administratives.</p>
                      </div>
                    </div>
                    <div class="reveal" style="padding-left:20px">
                      <span class="section-tag">Intelligence artificielle</span>
                      <h2>L'IA au service de<br />votre <em>conformité</em></h2>
                      <p class="section-lead" style="margin-bottom:32px">
                        Ibatix intègre des modules d'intelligence artificielle pour automatiser les contrôles réglementaires et réduire vos charges administratives à zéro.
                      </p>
                      <a href="#" class="btn-primary open-demo">Découvrir les fonctions IA</a>
                    </div>
                  </div>
                </section>

                <div id="clients">
                  <p>Ils nous font confiance</p>
                  <div class="clients-scroll">
                    <div class="client-badge">ENGIE</div>
                    <div class="client-badge">TotalEnergies</div>
                    <div class="client-badge">ADEME</div>
                    <div class="client-badge">Société Générale</div>
                    <div class="client-badge">Airwell</div>
                    <div class="client-badge">CAPEB</div>
                    <div class="client-badge">EBS Énergie</div>
                    <div class="client-badge">Esso</div>
                    <div class="client-badge">Siplec</div>
                    <div class="client-badge">Akeneo</div>
                  </div>
                </div>

                <div id="conformite">
                  <div class="conf-left">
                    <span class="section-tag">Conformité réglementaire</span>
                    <h2>Zéro papier,<br /><em>zéro erreur</em></h2>
                    <p class="section-lead">La rénovation énergétique est un secteur à forte charge administrative. Ibatix l'automatise entièrement.</p>
                    <ul class="conf-list">
                      <li>Génération automatique des formulaires Cerfa obligatoires</li>
                      <li>Dossiers CEE et MaPrimeRénov' pré-remplis et contrôlés</li>
                      <li>Signature électronique avec valeur juridique</li>
                      <li>Archivage sécurisé et traçabilité complète des documents</li>
                      <li>Mises à jour réglementaires incluses dans l'abonnement</li>
                    </ul>
                  </div>
                  <div class="conf-right reveal">
                    <span class="section-tag">Résultats mesurables</span>
                    <h2 style="font-size:2rem">Ce que vous gagnez<br /><em>concrètement</em></h2>
                    <div class="conf-highlight">
                      <div class="conf-highlight-label">Gain de temps moyen</div>
                      <p>Nos clients économisent en moyenne <strong style="color:var(--white)">12 heures par semaine</strong> sur les tâches administratives et de conformité.</p>
                    </div>
                    <div class="conf-highlight" style="margin-top:16px">
                      <div class="conf-highlight-label">Réduction des erreurs</div>
                      <p>Le taux de dossiers rejetés chute de <strong style="color:var(--white)">78 %</strong> dès les premiers mois d'utilisation.</p>
                    </div>
                    <div class="conf-highlight" style="margin-top:16px">
                      <div class="conf-highlight-label">Plateforme 100 % web</div>
                      <p>Accessible depuis n'importe quel appareil, partout sur le terrain — sans installation.</p>
                    </div>
                  </div>
                </div>

                <section id="cta">
                  <span class="section-tag reveal">Prêt à transformer votre gestion ?</span>
                  <h2 class="reveal">Rejoignez les <em>400 entreprises</em><br />qui font confiance à Ibatix</h2>
                  <p class="reveal">Demandez une démonstration gratuite et personnalisée. Notre équipe vous montre Ibatix adapté à votre activité, sans engagement.</p>
                  <div class="cta-actions reveal">
                    <a href="#" class="btn-primary open-demo" style="font-size:1rem; padding:16px 40px">
                      Planifier une démonstration
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <a t-attf-href="tel:#{res_company.phone}" class="btn-secondary" style="font-size:1rem; padding:16px 40px">Nous appeler directement</a>
                  </div>
                </section>

                <footer>
                  <div class="footer-top">
                    <div>
                      <div class="footer-brand-name">
                        <svg class="logo-mark" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <rect width="34" height="34" rx="9" fill="rgba(178,244,90,0.13)"/>
                          <path d="M17 5 L29 16 L5 16 Z" fill="rgba(178,244,90,0.22)" stroke="#B2F45A" stroke-width="1.4" stroke-linejoin="round"/>
                          <rect x="9" y="16" width="16" height="13" rx="1.5" fill="rgba(178,244,90,0.08)" stroke="#B2F45A" stroke-width="1.4"/>
                          <path d="M18.5 18 L14.5 23.5 H17.5 L15 29" stroke="#B2F45A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          <circle cx="17" cy="5" r="1.8" fill="#B2F45A"/>
                        </svg>
                        Ibatix
                      </div>
                      <p class="footer-brand-desc">Le logiciel de gestion de référence pour les entreprises de la rénovation énergétique. 100 % web, 100 % français.</p>
                    </div>
                    <div>
                      <div class="footer-col-title">Produit</div>
                      <ul class="footer-links">
                        <li><a href="#">Fonctionnalités</a></li>
                        <li><a href="#">Modules</a></li>
                        <li><a href="#">Tarifs</a></li>
                        <li><a href="#">Mises à jour</a></li>
                      </ul>
                    </div>
                    <div>
                      <div class="footer-col-title">Ressources</div>
                      <ul class="footer-links">
                        <li><a href="#">Helpdesk</a></li>
                        <li><a href="#">Academy</a></li>
                        <li><a href="#">Forum</a></li>
                        <li><a href="#">Documentation</a></li>
                      </ul>
                    </div>
                    <div>
                      <div class="footer-col-title">Entreprise</div>
                      <ul class="footer-links">
                        <li><a href="#">À propos</a></li>
                        <li><a href="#" class="open-demo">Contact</a></li>
                        <li><a href="#">Mentions légales</a></li>
                        <li><a href="#">RGPD</a></li>
                      </ul>
                    </div>
                  </div>
                  <div class="footer-bottom">
                    <p>© 2026 Ibatix · Illkirch-Graffenstaden, Alsace · Tous droits réservés</p>
                    <div class="eco-badge">
                      <div class="eco-dot"></div>
                      Bureaux alimentés par géothermie &amp; photovoltaïque
                    </div>
                  </div>
                </footer>

                <div id="demoModal" class="demo-modal">
                    <div class="demo-modal-overlay"></div>
                    <div class="demo-modal-content">
                        <button class="demo-modal-close" aria-label="Fermer">✕</button>
                        <div class="demo-modal-header">
                            <h3>Demander une <em>démo</em></h3>
                            <p>Laissez-nous vos coordonnées, notre équipe vous contactera rapidement.</p>
                        </div>

                        <form action="/website/form/" method="post" data-model_name="crm.lead" data-success_page="/" class="s_website_form" enctype="multipart/form-data">

                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="form-group">
                                <label>Nom de l'entreprise</label>
                                <input type="text" name="name" class="s_website_form_input" placeholder="Ex: Rénov' Énergie" required="1"/>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Nom complet</label>
                                    <input type="text" name="contact_name" class="s_website_form_input" placeholder="Jean Dupont" required="1"/>
                                </div>
                                <div class="form-group">
                                    <label>Téléphone</label>
                                    <input type="tel" name="phone" class="s_website_form_input" placeholder="06 12 34 56 78"/>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Adresse e-mail</label>
                                <input type="email" name="email_from" class="s_website_form_input" placeholder="jean@entreprise.fr" required="1"/>
                            </div>
                            <div class="form-group">
                                <label>Comment pouvons-nous vous aider ?</label>
                                <textarea name="description" class="s_website_form_input" rows="3" placeholder="Parlez-nous de vos besoins..."></textarea>
                            </div>
                            <button type="submit" class="btn-primary s_website_form_send" style="width: 100%; justify-content: center;">Envoyer ma demande</button>

                            <span id="s_website_form_result"></span>
                        </form>
                    </div>
                </div>

            </div>

            <style>
                header#top, footer.o_footer { display: none !important; }
            </style>
        </xpath>
    </template>
</odoo>
